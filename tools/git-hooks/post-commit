#!/bin/sh
# post-commit: auto-bump Cargo.toml version based on the just-recorded commit
# message. Default is a patch bump. The message can opt into stronger bumps:
#
#   ^MAJOR  → (major+1).1.0
#   ^MINOR  → major.(minor+1).0
#   default → major.minor.(patch+1)
#
# The hook reads HEAD's message, modifies Cargo.toml and Cargo.lock, then
# `git commit --amend --no-edit` to fold the bump into the same commit.
# A guard file prevents the amend from re-triggering this hook recursively.

set -e

GIT_DIR=$(git rev-parse --git-dir)
GUARD="$GIT_DIR/POST_COMMIT_BUMP_RUNNING"

# Recursion guard — amend fires post-commit again; the second pass exits here.
if [ -f "$GUARD" ]; then
    rm -f "$GUARD"
    exit 0
fi

# Bail unless we're actually in the texttv repo (don't bump some other crate
# if the hook somehow ends up active elsewhere).
if [ ! -f Cargo.toml ] || ! grep -q '^name = "texttv"' Cargo.toml; then
    exit 0
fi

MSG=$(git log -1 --pretty=%B)

if printf '%s' "$MSG" | grep -qE '\^MAJOR'; then
    KIND=major
elif printf '%s' "$MSG" | grep -qE '\^MINOR'; then
    KIND=minor
else
    KIND=patch
fi

CURRENT=$(grep -m1 -E '^version = "[0-9]+\.[0-9]+\.[0-9]+"' Cargo.toml \
    | sed -E 's/version = "([0-9]+\.[0-9]+\.[0-9]+)".*/\1/')
if [ -z "$CURRENT" ]; then
    echo "post-commit version-bump: could not parse current version" >&2
    exit 0
fi
MAJOR=$(printf '%s' "$CURRENT" | cut -d. -f1)
MINOR=$(printf '%s' "$CURRENT" | cut -d. -f2)
PATCH=$(printf '%s' "$CURRENT" | cut -d. -f3)

case "$KIND" in
    major) NEW="$((MAJOR + 1)).1.0" ;;
    minor) NEW="${MAJOR}.$((MINOR + 1)).0" ;;
    patch) NEW="${MAJOR}.${MINOR}.$((PATCH + 1))" ;;
esac

if [ "$CURRENT" = "$NEW" ]; then
    exit 0
fi

# Update Cargo.toml — replace only the first matching `version = ` line so we
# don't touch a dep that happens to be pinned to the same version.
awk -v old="version = \"$CURRENT\"" -v new="version = \"$NEW\"" '
    !done && $0 == old { print new; done = 1; next }
    { print }
' Cargo.toml > Cargo.toml.tmp && mv Cargo.toml.tmp Cargo.toml

# Update Cargo.lock if present — only the texttv [[package]] entry.
if [ -f Cargo.lock ]; then
    awk -v new="version = \"$NEW\"" '
        BEGIN { matched = 0 }
        /^\[\[package\]\]$/ { matched = 0 }
        /^name = "texttv"$/ { matched = 1; print; next }
        matched && /^version = / { print new; matched = 0; next }
        { print }
    ' Cargo.lock > Cargo.lock.tmp && mv Cargo.lock.tmp Cargo.lock
fi

touch "$GUARD"
git add Cargo.toml
if [ -f Cargo.lock ]; then
    git add Cargo.lock
fi
git commit --amend --no-edit --no-verify >/dev/null

echo "version bumped: $CURRENT → $NEW ($KIND)" >&2
